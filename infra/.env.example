# Neurobotika Infrastructure Configuration
# ==========================================
#
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# This file is used by:
#   - Terraform (via terraform.tfvars auto-generated from .env)
#   - Pipeline scripts (via `source .env` or direnv)
#   - Docker containers (via --env-file)
#
# NEVER commit .env to git — it contains secrets and account-specific values.

# ──────────────────────────────────────────
# AWS Account & Region
# ──────────────────────────────────────────

# Your AWS region (all resources will be created here)
AWS_REGION=eu-central-1

# AWS CLI profile name (from ~/.aws/credentials or ~/.aws/config).
# Used by Terraform, AWS CLI, and all pipeline scripts.
AWS_PROFILE=neurobotika

# ──────────────────────────────────────────
# Project Settings
# ──────────────────────────────────────────

# Prefix for all AWS resource names (S3 buckets, ECR repos, etc.)
# Must be globally unique for S3 bucket names.
PROJECT_NAME=neurobotika

# Custom domain for CloudFront (leave empty to use the default *.cloudfront.net URL)
DOMAIN_NAME=

# Set to true to create pipeline compute resources (Batch, ECR, VPC, Step Functions).
# Start with false for web-hosting only; set to true when ready to run the pipeline.
ENABLE_PIPELINE=false

# ──────────────────────────────────────────
# S3 Buckets
# ──────────────────────────────────────────
# These are derived from PROJECT_NAME by Terraform, but pipeline scripts
# need the full bucket names for `aws s3 cp` commands.

DATA_BUCKET=${PROJECT_NAME}-data
PUBLIC_BUCKET=${PROJECT_NAME}-public
WEB_BUCKET=${PROJECT_NAME}-web

# ──────────────────────────────────────────
# ECR (Container Registry)
# ──────────────────────────────────────────
# AWS account ID is needed to construct ECR image URIs.
# Find yours with: aws sts get-caller-identity --query Account --output text

AWS_ACCOUNT_ID=

# ECR repository names (created by Terraform)
ECR_REPO_BRAIN=${PROJECT_NAME}-brain
ECR_REPO_SPINE=${PROJECT_NAME}-spine
ECR_REPO_POSTPROC=${PROJECT_NAME}-postproc
ECR_REPO_TRAINING=${PROJECT_NAME}-training

# ──────────────────────────────────────────
# Compute (AWS Batch)
# ──────────────────────────────────────────

# GPU instance types for Batch compute environments (Phases 2, 3, 7)
# g4dn.xlarge is recommended for eu-central-1 (best spot pricing)
GPU_INSTANCE_TYPES=g4dn.xlarge,g5.xlarge,g6.xlarge

# CPU instance types for Batch compute environments (Phases 1, 5, 6)
CPU_INSTANCE_TYPES=c6i.4xlarge,c7i.4xlarge,c6i.2xlarge

# Network-optimized instance for downloads (Phase 1)
# c6gn.4xlarge provides 25 Gbps sustained bandwidth
DOWNLOAD_INSTANCE_TYPES=c6gn.xlarge,c6gn.4xlarge,c6i.xlarge

# Maximum vCPUs for Batch compute environments (controls cost ceiling)
GPU_MAX_VCPUS=8
CPU_MAX_VCPUS=32

# ──────────────────────────────────────────
# EFS (Optional Shared Filesystem)
# ──────────────────────────────────────────
# Set to "true" to create an EFS filesystem for inter-phase data sharing.
# Recommended: "false" initially — use S3 cp instead (cheaper, simpler).

ENABLE_EFS=false

# ──────────────────────────────────────────
# Step Functions
# ──────────────────────────────────────────
# SNS topic for Phase 4 manual segmentation notifications.
# When the pipeline reaches Phase 4, it sends an email to this address
# with a callback token. Reply when manual work is done.

NOTIFICATION_EMAIL=

# ──────────────────────────────────────────
# Pipeline Script Settings
# ──────────────────────────────────────────
# S3 prefix used by pipeline scripts for remote data access
# (passed as --s3-prefix to individual scripts)

S3_DATA_PREFIX=s3://${DATA_BUCKET}
S3_PUBLIC_PREFIX=s3://${PUBLIC_BUCKET}
